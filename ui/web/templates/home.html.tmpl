<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atrium</title>
  <meta
    name="description"
    content="Atrium"
  >
  <style>
    :root {
      color-scheme: dark;
      --bg: #111317;
      --bg-elevated: #171a20;
      --border: #2a3038;
      --text: #d9dde3;
      --muted: #9098a3;
      --accent: #8fbf8f;
      --accent-dim: rgba(143, 191, 143, 0.12);
      --shadow: 0 18px 48px rgba(0, 0, 0, 0.28);
      --radius: 14px;
      --content-width: 1120px;
      --mono: "JetBrains Mono", "Fira Code", "IBM Plex Mono", "Cascadia Code", monospace;
      --sans: "Inter", "Segoe UI", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--sans);
      background:
        radial-gradient(circle at top, rgba(143, 191, 143, 0.08), transparent 24%),
        linear-gradient(180deg, #0e1014 0%, var(--bg) 100%);
      color: var(--text);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .page-shell {
      width: min(100% - 2rem, var(--content-width));
      margin: 0 auto;
      padding: 1rem 0 4rem;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1rem;
      padding: 0.9rem 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: rgba(23, 26, 32, 0.8);
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: var(--mono);
      letter-spacing: 0.02em;
      text-transform: lowercase;
    }

    .brand::before {
      content: ">_";
      color: var(--accent);
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.95rem;
    }

    .nav a:hover,
    .nav a:focus-visible {
      color: var(--text);
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
      gap: 1.25rem;
      margin-top: 1.25rem;
    }

    .panel {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: rgba(23, 26, 32, 0.86);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.02);
      font-family: var(--mono);
      font-size: 0.86rem;
      color: var(--muted);
    }

    .panel-dots {
      display: inline-flex;
      gap: 0.4rem;
    }

    .panel-dots span {
      width: 0.62rem;
      height: 0.62rem;
      border-radius: 999px;
      background: #303743;
    }

    .panel-body {
      padding: 1.4rem;
    }

    .eyebrow {
      margin: 0 0 0.85rem;
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1 {
      font-size: clamp(2.6rem, 5vw, 4.8rem);
      line-height: 0.96;
      letter-spacing: -0.05em;
      margin-bottom: 1rem;
    }

    .hero-copy {
      max-width: 62ch;
      color: #c1c7cf;
      font-size: 1.02rem;
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      padding: 0.75rem 1rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-family: var(--mono);
      font-size: 0.92rem;
      transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
    }

    .button.primary {
      border-color: rgba(143, 191, 143, 0.5);
      background: var(--accent-dim);
      color: var(--text);
    }

    .button:hover,
    .button:focus-visible {
      border-color: var(--accent);
      background: rgba(143, 191, 143, 0.16);
      outline: none;
    }

    .terminal-lines {
      display: grid;
      gap: 0.9rem;
      font-family: var(--mono);
      font-size: 0.93rem;
      line-height: 1.7;
    }

    .terminal-line {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.85rem;
      align-items: start;
    }

    .prompt {
      color: var(--accent);
      user-select: none;
    }

    .muted {
      color: var(--muted);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1.25rem;
      margin-top: 1.25rem;
    }

    .span-7 {
      grid-column: span 7;
    }

    .span-5 {
      grid-column: span 5;
    }

    .list {
      display: grid;
      gap: 0.9rem;
    }

    .list-item {
      padding: 0.9rem 1rem;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
    }

    .list-item:hover {
      border-color: #3d4653;
    }

    .list-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 0.55rem;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.82rem;
    }

    .list-item h3 {
      margin-bottom: 0.45rem;
      font-size: 1.06rem;
    }

    .list-item p {
      margin-bottom: 0;
      color: #b8bec8;
      line-height: 1.65;
    }

    .tag-list,
    .link-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    .tag,
    .chip {
      display: inline-flex;
      align-items: center;
      padding: 0.45rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-family: var(--mono);
      font-size: 0.82rem;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.02);
    }

    .footer {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1.25rem;
      padding: 1rem 0.2rem 0;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.85rem;
    }

    @media (max-width: 940px) {
      .hero,
      .grid {
        grid-template-columns: 1fr;
      }

      .span-7,
      .span-5 {
        grid-column: auto;
      }
    }

    @media (max-width: 640px) {
      .page-shell {
        width: min(100% - 1rem, var(--content-width));
        padding-bottom: 2.4rem;
      }

      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .panel-body {
        padding: 1.1rem;
      }

      h1 {
        font-size: 2.4rem;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <header class="topbar">
      <a class="brand" href="/">atrium</a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="/about/">about</a>
        <a href="/blog/">blog</a>
        <a href="/projects/">projects</a>
        <a href="/tags/">tags</a>
        <a href="#links">links</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <article class="panel">
          <div class="panel-head">
            <span>~/atrium/home</span>
            <div class="panel-dots" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
          <div class="panel-body">
            <p class="eyebrow">Personal website / technical portfolio</p>
            <h1 id="hero-title">Atrium</h1>
            <p class="hero-copy">
              Software notes, projects, and writing collected in one place. This homepage is the
              entry point to a small body of work shaped around building things carefully, learning
              in public, and keeping the web experience direct.
            </p>
            <div class="hero-actions">
              <a class="button primary" href="/blog/">Open writings</a>
              <a class="button" href="/projects/">Inspect projects</a>
            </div>
          </div>
        </article>

        <aside class="panel" aria-label="Terminal summary">
          <div class="panel-head">
            <span>session.log</span>
            <span class="muted">status: online</span>
          </div>
          <div class="panel-body terminal-lines">
            <div class="terminal-line">
              <span class="prompt">$</span>
              <span>focus: backend engineering, tooling, and practical systems</span>
            </div>
            <div class="terminal-line">
              <span class="prompt">$</span>
              <span>writing: posts, notes, and implementation breakdowns</span>
            </div>
            <div class="terminal-line">
              <span class="prompt">$</span>
              <span>projects: selected work with context, tradeoffs, and code links</span>
            </div>
            <div class="terminal-line">
              <span class="prompt">$</span>
              <span class="muted">next: replace placeholder copy with your actual introduction</span>
            </div>
          </div>
        </aside>
      </section>

      <section class="grid" aria-label="Homepage sections">
        <article class="panel span-7">
          <div class="panel-head">
            <span>recent_posts</span>
            <a href="/blog/">view all</a>
          </div>
          <div class="panel-body list">
            <a class="list-item" href="/blog/example/">
              <div class="list-meta">
                <span>2026-04-20</span>
                <span>slug: example</span>
                <span>tag: programming</span>
              </div>
              <h3>Example post title</h3>
              <p>
                A short preview of the post content will live here so visitors can quickly scan what
                the writing is about before opening the full article.
              </p>
            </a>

            <div class="list-item">
              <div class="list-meta">
                <span>placeholder</span>
                <span>future content</span>
              </div>
              <h3>More posts will be listed here</h3>
              <p>
                Once your generator reads the markdown directory, this section can be filled
                automatically from the latest published posts.
              </p>
            </div>
          </div>
        </article>

        <aside class="panel span-5">
          <div class="panel-head">
            <span>tag_index</span>
            <a href="/tags/">browse</a>
          </div>
          <div class="panel-body">
            <p class="eyebrow">Topics</p>
            <div class="tag-list">
              <a class="tag" href="/tags/go/">go</a>
              <a class="tag" href="/tags/linux/">linux</a>
              <a class="tag" href="/tags/backend/">backend</a>
              <a class="tag" href="/tags/tooling/">tooling</a>
              <a class="tag" href="/tags/programming/">programming</a>
            </div>
          </div>
        </aside>

        <article class="panel span-7">
          <div class="panel-head">
            <span>projects_overview</span>
            <a href="/projects/">all projects</a>
          </div>
          <div class="panel-body list">
            <div class="list-item">
              <div class="list-meta">
                <span>featured project</span>
                <span>repo available</span>
              </div>
              <h3>Project title placeholder</h3>
              <p>
                Use this space to highlight one project with a short description, its main idea,
                and a link to the repository or demo once the projects page is added.
              </p>
            </div>
          </div>
        </article>

        <aside class="panel span-5" id="links">
          <div class="panel-head">
            <span>external_links</span>
            <span class="muted">contact</span>
          </div>
          <div class="panel-body">
            <p class="eyebrow">Profiles</p>
            <div class="link-list">
              <a class="chip" href="#">github</a>
              <a class="chip" href="#">linkedin</a>
              <a class="chip" href="#">email</a>
            </div>
          </div>
        </aside>
      </section>
    </main>

    <footer class="footer">
      <span>Built for static generation.</span>
      <span>Atrium / home</span>
    </footer>
  </div>
</body>
</html>
